{
  "entities": {
    "token": {
      "title": "Crypto Token",
      "description": "A tracked cryptocurrency token in the NeuroNova ecosystem.",
      "type": "object",
      "properties": {
        "symbol": { "type": "string", "description": "Ticker symbol (e.g. BTC)" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "change24h": { "type": "number" },
        "marketCap": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["symbol", "price"]
    },
    "marketSignal": {
      "title": "Alpha Signal",
      "description": "High-fidelity trading signal generated by the neural core.",
      "type": "object",
      "properties": {
        "tokenId": { "type": "string" },
        "signalType": { "type": "string", "enum": ["BUY", "SELL", "NEUTRAL"] },
        "confidence": { "type": "number" },
        "reasoning": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "tokens": {
      "schema": "token",
      "description": "Live tracking of assets."
    },
    "signals": {
      "schema": "marketSignal",
      "description": "Predictive neural signals."
    }
  }
}
